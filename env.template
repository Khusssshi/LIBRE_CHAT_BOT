# LibreChat Environment Configuration Template
# Copy this file to .env and configure your settings

# Database Configuration
MONGO_URI=mongodb://localhost:27017/LibreChat
DB_CONNECTION_STRING=mongodb://localhost:27017/LibreChat

# Google/Gemini Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_KEY=your_gemini_api_key_here

# Optional: Google Service Account (for Vertex AI)
# GOOGLE_SERVICE_KEY_FILE=./data/auth.json

# Optional: Google Cloud Project (for Vertex AI)
# GOOGLE_PROJECT_ID=your_project_id

# Optional: Google Location (for Vertex AI)
# GOOGLE_LOC=us-central1

# Optional: Reverse Proxy for Google API
# GOOGLE_REVERSE_PROXY=

# Optional: Custom Auth Header
# GOOGLE_AUTH_HEADER=false

# Server Configuration
HOST=localhost
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# Security (generate secure random strings)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Optional: Other AI Providers (uncomment if needed)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# Optional: Redis Configuration (for caching)
# REDIS_URI=redis://localhost:6379

# Optional: File Storage
# FILE_STRATEGY=local
# UPLOAD_LIMIT=10

# Optional: Email Configuration (for user registration)
# EMAIL_SERVICE=gmail
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# Optional: Social Login (uncomment if needed)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret


